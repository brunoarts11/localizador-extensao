{
  "manifest_version": 3,
  "name": "Localizador de Documentos - 11ª CIPM/PMPE",
  "version": "1.0.1",
  "description": "Localize SUNORs e consulte a legislacao e o conteúdo dos documentos da 11ª CIPM/PMPE.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": { "default_title": "Abrir Localizador de Documentos" },
  "side_panel": { "default_path": "sidepanel.html" },
  "background": { "service_worker": "service_worker.js" },
  "permissions": ["sidePanel", "storage"],
  "host_permissions": ["https://n8n.ebruno.com.br/*"]
}
